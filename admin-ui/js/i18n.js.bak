    "Timetable Grid": "Ø´Ø¨ÙƒØ© Ø§Ù„Ø¬Ø¯ÙˆÙ„ Ø§Ù„Ø²Ù…Ù†ÙŠ",
    "No time slots yet": "Ù„Ø§ ØªÙˆØ¬Ø¯ ÙØªØ±Ø§Øª Ø²Ù…Ù†ÙŠØ© Ø¨Ø¹Ø¯",
    "Add Time Slot": "Ø¥Ø¶Ø§ÙØ© ÙØªØ±Ø© Ø²Ù…Ù†ÙŠØ©",
    "to build the timetable rows.": "Ù„Ø¨Ù†Ø§Ø¡ ØµÙÙˆÙ Ø§Ù„Ø¬Ø¯ÙˆÙ„ Ø§Ù„Ø²Ù…Ù†ÙŠ.",
    "Activate": "ØªÙØ¹ÙŠÙ„",
    "Download PDF": "ØªÙ†Ø²ÙŠÙ„ PDF",
    "Program Name": "Ø§Ø³Ù… Ø§Ù„Ø¨Ø±Ù†Ø§Ù…Ø¬",
    "e.g. 2025-2026 Semester 1": "Ù…Ø«Ø§Ù„: 2025-2026 Ø§Ù„ÙØµÙ„ 1",
    "Optional notes about this program": "Ù…Ù„Ø§Ø­Ø¸Ø§Øª Ø§Ø®ØªÙŠØ§Ø±ÙŠØ© Ø­ÙˆÙ„ Ù‡Ø°Ø§ Ø§Ù„Ø¨Ø±Ù†Ø§Ù…Ø¬",
    "Label": "Ø§Ù„ØªØ³Ù…ÙŠØ©",
    "e.g. 08:00 - 09:00": "Ù…Ø«Ø§Ù„: 08:00 - 09:00",
    "Start Time": "ÙˆÙ‚Øª Ø§Ù„Ø¨Ø¯Ø§ÙŠØ©",
    "End Time": "ÙˆÙ‚Øª Ø§Ù„Ù†Ù‡Ø§ÙŠØ©",
    "Sort Order": "ØªØ±ØªÙŠØ¨ Ø§Ù„Ø¹Ø±Ø¶",
    "Add Schedule Entry": "Ø¥Ø¶Ø§ÙØ© ØªØ³Ø¬ÙŠÙ„ Ø¬Ø¯ÙˆÙ„ÙŠ",
    "Subject / Science Name": "Ø§Ù„Ù…Ø§Ø¯Ø© / Ø§Ø³Ù… Ø§Ù„Ø¹Ù„Ù…",
    "e.g. Mathematics, Physics, Arabic...": "Ù…Ø«Ø§Ù„: Ø±ÙŠØ§Ø¶ÙŠØ§Øª, ÙÙŠØ²ÙŠØ§Ø¡, Ø¹Ø±Ø¨ÙŠØ©...",
    "Color": "Ø§Ù„Ù„ÙˆÙ†",
    "Save Entry": "Ø­ÙØ¸ Ø§Ù„ØªØ³Ø¬ÙŠÙ„",
    "Loading classrooms...": "Ø¬Ø§Ø± ØªØ­Ù…ÙŠÙ„ Ø§Ù„Ø£Ù‚Ø³Ø§Ù…...",
    "Loading teachers...": "Ø¬Ø§Ø± ØªØ­Ù…ÙŠÙ„ Ø§Ù„Ø£Ø³Ø§ØªØ°Ø©...",
    "Loading groups...": "Ø¬Ø§Ø± ØªØ­Ù…ÙŠÙ„ Ø§Ù„Ø£ÙÙˆØ§Ø¬...",
  },

  // â”€â”€ Language init â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  init: function () {
    this.currentLang = localStorage.getItem('app_lang') || 'en';
    if (this.currentLang === 'ar') {
      document.documentElement.dir = 'rtl';
      document.documentElement.lang = 'ar';
      this.addRtlStyles();
    } else {
      document.documentElement.dir = 'ltr';
      document.documentElement.lang = 'en';
    }
  },

  // â”€â”€ RTL layout styles â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  addRtlStyles: function () {
    if (document.getElementById('rtl-styles')) return;
    const style = document.createElement('style');
    style.id = 'rtl-styles';
    style.innerHTML = `
      @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap');

      body, h1, h2, h3, h4, h5, h6, p, label, a, button, span, td, th {
        font-family: 'Tajawal', 'Inter', sans-serif !important;
      }

      /* Sidebar: move to right side */
      #app-sidebar {
        left: auto !important;
        right: 0 !important;
        transform: translateX(100%) !important;
        box-shadow: -4px 0 24px rgba(0,0,0,.18) !important;
      }
      body.sb-open #app-sidebar {
        transform: translateX(0) !important;
      }
      body.sb-collapsed #app-sidebar {
        transform: translateX(100%) !important;
      }

      /* Fixed mode RTL: sidebar on right, content margin on right */
      body.sb-fixed #app-sidebar {
        transform: translateX(0) !important;
        left: auto !important;
        right: 0 !important;
      }
      body.sb-fixed .sb-main {
        margin-left: 0 !important;
        margin-right: var(--sb-width) !important;
        height: 100vh !important;
        overflow-y: auto !important;
      }
      body.sb-fixed.sb-collapsed .sb-main {
        margin-right: 68px !important;
        margin-left: 0 !important;
      }

      /* Main content: margin on right instead of left */
      .sb-main {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }

      /* Active sidebar indicator: right side */
      .sb-link.active::before {
        left: auto !important;
        right: 0 !important;
      }

      /* Topbar */
      .sb-topbar {
        flex-direction: row-reverse;
      }

      /* Arrow flip in sidebar */
      .sb-arrow {
        transform: scaleX(-1) !important;
        margin-left: 0 !important;
        margin-right: auto !important;
      }
      .sb-item.open > .sb-link .sb-arrow {
        transform: scaleX(-1) rotate(90deg) !important;
      }

      /* Dropdowns on left for RTL */
      .lang-dropdown, .topbar-dropdown {
        right: auto !important;
        left: 0 !important;
      }

      /* Form text align */
      input:not([type=checkbox]):not([type=radio]),
      select,
      textarea {
        text-align: right;
        direction: rtl;
      }

      /* Breadcrumb icon */
      .sb-breadcrumb {
        flex-direction: row-reverse;
        justify-content: flex-end;
      }

      /* Submenu indentation flipped */
      .sb-submenu li a {
        padding: 0 52px 0 16px !important;
      }

      /* Table header text */
      .table th { text-align: right !important; }
      .table td { text-align: right !important; }
      .table-custom th { text-align: right !important; }
      .table-custom td { text-align: right !important; }

      /* Buttons with icons */
      .btn i { margin-right: 0 !important; margin-left: 4px !important; }

      /* stat-icon margin */
      .stat-icon { margin-right: 0 !important; margin-left: 16px !important; }
    `;
    document.head.appendChild(style);
  },

  // â”€â”€ Smart text node translator â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  _translateTextNode: function (node) {
    const raw = node.nodeValue;
    const trimmed = raw.trim();
    if (!trimmed) return;

    // Direct match on trimmed text
    if (this.dict[trimmed]) {
      node.nodeValue = raw.replace(trimmed, this.dict[trimmed]);
      return;
    }

    // Partial sweep: check if any dict key appears as a whole-word substring
    // (useful for cases like " Save Student" where there's leading whitespace)
    for (const [en, ar] of Object.entries(this.dict)) {
      if (trimmed === en) {
        node.nodeValue = raw.replace(en, ar);
        return;
      }
    }
  },

  // â”€â”€ Walk the DOM â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  _walk: function (node) {
    if (!node) return;

    // Skip script, style, svg
    const skipTags = ['SCRIPT', 'STYLE', 'SVG', 'CANVAS', 'CODE', 'PRE'];
    if (node.nodeType === Node.ELEMENT_NODE && skipTags.includes(node.tagName)) return;

    if (node.nodeType === Node.TEXT_NODE) {
      this._translateTextNode(node);
      return;
    }

    if (node.nodeType === Node.ELEMENT_NODE) {
      // Translate placeholder attribute
      const ph = node.getAttribute('placeholder');
      if (ph && this.dict[ph]) node.setAttribute('placeholder', this.dict[ph]);

      // Translate title attribute
      const ti = node.getAttribute('title');
      if (ti && this.dict[ti]) node.setAttribute('title', this.dict[ti]);

      // Input button/submit value
      if (node.tagName === 'INPUT' && (node.type === 'button' || node.type === 'submit')) {
        const val = (node.value || '').trim();
        if (val && this.dict[val]) node.value = this.dict[val];
      }

      // Walk children
      for (let child of Array.from(node.childNodes)) {
        this._walk(child);
      }
    }
  },

  // â”€â”€ Public: translate a root element (or full page) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  translateAll: function (rootNode) {
    if (this.currentLang !== 'ar') {
      // Still update the lang label
      const lbl = document.getElementById('lang-current-label');
      if (lbl) lbl.textContent = 'EN';
      return;
    }

    const root = rootNode || document.body;
    this._walk(root);

    // Update language button label
    const lbl = document.getElementById('lang-current-label');
    if (lbl) lbl.textContent = 'AR';
  },

  // â”€â”€ Save lang + reload â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  setLang: function (lang) {
    localStorage.setItem('app_lang', lang);
    window.location.reload();
  }
};

// â”€â”€ Bootstrap â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
AppI18n.init();

// Translate the static HTML after DOM is ready
document.addEventListener('DOMContentLoaded', function () {
  AppI18n.translateAll();
});

// Global helper called by lang switcher buttons
window.setAppLanguage = function (lang) {
  AppI18n.setLang(lang);
};

